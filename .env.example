# iCloud 邮箱管理面板 环境变量配置
# 复制此文件为 .env 并填入你的实际值（.env 不会被 Git 追踪）

# ── 面板密码（必填） ──
# 用于登录本地面板的密码，默认值为 "changeme"
# 正式使用前请务必修改：
ICLOUD_PANEL_PASSWORD=changeme

# ── 扫描与网络（可选） ──
# 扫描并发线程数，默认 5，范围 1–16
# ICLOUD_SCAN_WORKERS=5

# 每次 HTTP 请求超时秒数，默认 25，范围 5–90
# ICLOUD_FETCH_TIMEOUT=25

# 单次请求最多重试次数，默认 4，范围 0–8
# ICLOUD_FETCH_RETRIES=4

# 失败账号自动重试轮次间隔秒数，默认 30，范围 5–300
# ICLOUD_RETRY_DELAY=30

# 最多自动重试轮次，默认 3，范围 1–10
# ICLOUD_MAX_RETRY_PASSES=3
